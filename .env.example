# Google Cloud Platform (GCP) / Gemini API Configuration
# Accessed ONLY via Next.js server-side routes — never expose to the browser.

# GCP project ID for Vertex AI Gemini access
GCP_PROJECT_ID=your_gcp_project_id

# GCP region where Vertex AI is enabled (default: us-central1)
GCP_LOCATION=us-central1

# Authentication: Application Default Credentials (ADC)
# Local development:
#   1. Install Google Cloud SDK: https://cloud.google.com/sdk/docs/install
#   2. Run: gcloud auth application-default login
#   3. Set project: gcloud config set project YOUR_PROJECT_ID
#
# Cloud Run / GCE deployment:
#   Attach a service account with Vertex AI User role — ADC is automatic.
#
# No API key is required when using Vertex AI with ADC.
